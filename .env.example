# Copy this file to .env and fill in your keys.
# docker-compose automatically loads .env from this directory.
# .env is gitignored — never commit real keys.

# Seats.aero Partner API — powers Award Search
SEATS_API_KEY=

# RapidAPI / Sky Scrapper — business & premium cash prices
RAPIDAPI_KEY=

# Travelpayouts — economy cash price baseline
TRAVELPAYOUTS_TOKEN=
